{
  "$schema": "https://protocol.ampersandboxdesign.com/v0.1/schema.json",
  "agent": "InfraOperator",
  "version": "1.0.0",
  "capabilities": {
    "&memory.graph": {
      "provider": "graphonomous",
      "config": {
        "instance": "infra-ops"
      }
    },
    "&time.anomaly": {
      "provider": "ticktickclock",
      "config": {
        "streams": ["cpu", "mem"]
      }
    },
    "&space.fleet": {
      "provider": "geofleetic",
      "config": {
        "regions": ["us-east"]
      }
    },
    "&reason.argument": {
      "provider": "deliberatic",
      "config": {
        "governance": "constitutional"
      }
    }
  },
  "governance": {
    "hard": [
      "Never scale beyond 3x in a single action"
    ],
    "soft": [
      "Prefer gradual scaling over spikes"
    ],
    "escalate_when": {
      "confidence_below": 0.7,
      "cost_exceeds_usd": 1000
    }
  },
  "provenance": true
}
